# Core secrets (generate with openssl rand -hex 32)
DB_PASSWORD=senqo
JWT_SECRET=change-me-to-a-random-64-char-string
API_KEY_PEPPER=change-me-to-a-random-pepper-string
WORKSPACE_SECRETS_KEY=change-me-to-a-random-64-char-hex-string
WHATSAPP_SERVICE_API_KEY=change-me-to-a-random-64-char-hex-string
WHATSAPP_WEBHOOK_AUTHORIZATION=change-me-to-a-random-64-char-hex-string
NODE_ENV=production

# Public URL — HTTPS on VPS; see README for Caddy setup
FRONTEND_URL=https://<VPS_PUBLIC_IP>
# Optional public API host for POST /api/tasks (hostname or URL). Falls back to FRONTEND_URL when unset.
API_URL=
AUTH_COOKIE_SECURE=true
ALLOWED_PRODUCTION_ORIGINS=<VPS_PUBLIC_IP>
DEV_FRONTEND_PORT=8080

# Cloudflare R2 (S3-compatible media storage)
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=senqo-wa
S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>

# AI agent (openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# ── Email (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=smtp_user
SMTP_PASS=smtp_password
SMTP_FROM_EMAIL=Your App <no-reply@your-verified-domain.com>

# First boot on empty DB — toggle registration later in Instance admin
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=your-secure-password-here
BOOTSTRAP_WORKSPACE_NAME=My Workspace
ALLOW_PUBLIC_REGISTRATION=false

# Seconds to batch inbound WhatsApp messages before the agent runs (1–60)
INBOUND_AI_DEBOUNCE_SECONDS=7
