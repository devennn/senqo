# ── Required ───────────────────────────────────────────────────
DATABASE_URL=postgresql://senqo:senqo@postgres:5432/senqo
JWT_SECRET=change-me-to-a-random-64-char-string
# Local Compose (http://localhost:8080): false so refresh cookies work. Use true behind HTTPS.
AUTH_COOKIE_SECURE=false

# ── Storage (Cloudflare R2 — S3-compatible) ────────────────────
# See README "Storage: Cloudflare R2" for free setup. The endpoint must be the
# public R2 S3 API endpoint (browsers load presigned media URLs directly from it).
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=senqo-wa
S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>

# ── AI ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── WhatsApp (first-party Baileys service in Compose, name: whatsapp) ─
# Shared secret used as the webhook ?token= the backend validates (whatsapp → backend).
WHATSAPP_WEBHOOK_AUTHORIZATION=<YOUR_WEBHOOK_AUTH_TOKEN>
# Backend → whatsapp service inside Docker (container port 8080; host uses localhost:3002).
WHATSAPP_SERVICE_URL=http://whatsapp:8080
# Shared secret the backend presents to the whatsapp service as the x-api-key header.
# A password you choose yourself; it must match WHATSAPP_SERVICE_API_KEY on the whatsapp service.
WHATSAPP_SERVICE_API_KEY=your-whatsapp-service-api-key-here
# Hosts allowed for WhatsApp media download inside the backend network.
WHATSAPP_MEDIA_ALLOWED_HOSTS=whatsapp,localhost

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Senqo Notifications <no-reply@notification.senqo.app>

# ── Other ───────────────────────────────────────────────────────
API_KEY_PEPPER=change-me-to-a-random-pepper-string
# AES key for encrypted workspace secrets (custom agent tools). Generate: openssl rand -hex 32
WORKSPACE_SECRETS_KEY=change-me-to-a-random-64-char-hex-string
# Required for isolated-vm on Node 20+ (set in Docker backend image; optional for local dev)
# NODE_OPTIONS=--no-node-snapshot
# Optional: extra production CORS origins beyond senqo.app and its subdomains
# (comma-separated hostnames, e.g. preview deploys: app-preview.vercel.app,staging.example.com)
# ALLOWED_PRODUCTION_ORIGINS=
# Optional: Postgres password for Compose `postgres` / `migrate` (default senqo)
# DB_PASSWORD=senqo
# Optional: quiet inbound bursts before agent runs (default 7; max 60)
# INBOUND_AI_DEBOUNCE_SECONDS=7
NODE_ENV=production

# Dev stack only: use `docker compose --env-file .env ...` (see README). Default 80 = nginx.
# FRONTEND_CONTAINER_PORT=5173
